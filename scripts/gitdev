#!/bin/bash

set -e

# Check branch name
if [ -z "$1" ]; then
  echo "Usage: gitdev <new branch name>"
  exit 1
fi

# Update remote references
git fetch origin

# Check if branch already exists
if git show-ref --verify --quiet "refs/heads/$1" || \
   git show-ref --verify --quiet "refs/remotes/origin/$1"; then
  echo "Branch '$1' already exists."
  exit 1
fi

# Validate branch name format
if [[ ! "$1" =~ ^(feature|fix|hotfix|refactor)/.+$ ]]; then
  echo "Branch name must start with feature/, fix/, hotfix/, or refactor/ followed by a descriptive name."
  exit 1
fi

# Check for uncommitted changes
if [ -n "$(git status --porcelain)" ]; then
  echo "Working tree is not clean."
  exit 1
fi

# Switch to develop branch
git switch develop

# Update develop branch
git reset --hard origin/develop

# Create and switch to new branch
git switch -c "$1"

echo "Successfully created and switched to branch '$1'."